---

<footer class="wp-footer" role="contentinfo" aria-label="Pie de página">
  <div class="wp-footer__divider" aria-hidden="true"></div>

  <!-- Contenido principal -->
  <div
    class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12 grid grid-cols-1 gap-10 md:grid-cols-3 md:gap-12"
  >
    <!-- Col 1: Branding -->
    <div class="wp-footer__brand flex flex-col gap-3">
      <img
        src="/images/letra-w-40.png"
        alt="Logo Waldo Fernandez"
        width="40"
        height="40"
        loading="lazy"
      />
      <span class="wp-footer__name text-lg font-semibold tracking-tight"
        >Waldo Fernandez</span
      >
      <p class="wp-footer__tagline text-sm leading-relaxed">
        Ingeniero de Software apasionado por el desarrollo web y la tecnología.
      </p>
    </div>

    <!-- Col 2: Contacto -->
    <div class="flex flex-col gap-4">
      <h3
        class="wp-footer__heading text-xs font-semibold uppercase tracking-widest"
      >
        Contacto
      </h3>
      <ul class="flex flex-col gap-3" role="list">
        {
          contactInfo.map(({ svg, label, value, href }) => (
            <li class="wp-footer__contact-item">
              <span class="wp-footer__contact-icon" set:html={svg} />
              <span class="wp-footer__contact-label text-[0.7rem] font-medium uppercase tracking-wide">
                {label}
              </span>
              {href ? (
                <a
                  href={href}
                  class="wp-footer__contact-value wp-footer__contact-link text-sm"
                >
                  {value}
                </a>
              ) : (
                <span class="wp-footer__contact-value text-sm">{value}</span>
              )}
            </li>
          ))
        }
      </ul>
    </div>

    <!-- Col 3: Redes sociales -->
    <div class="flex flex-col gap-4">
      <h3
        class="wp-footer__heading text-xs font-semibold uppercase tracking-widest"
      >
        Redes
      </h3>
      <ul class="flex flex-col gap-3" role="list">
        {
          socialLinks.map(({ label, url, svg }) => (
            <li>
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="wp-footer__social-link inline-flex items-center gap-2.5 text-sm px-3 py-2 rounded-lg"
                aria-label={`Visitar perfil de ${label}`}
              >
                <span set:html={svg} />
                <span>{label}</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>
  </div>

  <!-- Bottom bar: copyright -->
  <div class="wp-footer__bottom px-4 py-5 text-center">
    <p class="wp-footer__copyright text-xs tracking-wide">
      © <span data-year></span> Waldo Fernandez · Todos los derechos reservados
    </p>
  </div>
</footer>

<!-- Botón flotante "volver arriba" -->
<button
  type="button"
  class="wp-back-to-top fixed bottom-8 right-8 z-40 flex items-center justify-center w-12 h-12 rounded-full"
  id="back-to-top"
  aria-label="Volver al inicio de la página"
  data-visible="false"
>
  <img
    src="/images/letra-w-40.png"
    alt=""
    aria-hidden="true"
    width="40"
    height="40"
  />
</button>

<script src="../scripts/footer.ts"></script>
