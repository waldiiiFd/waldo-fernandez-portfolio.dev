---
import { getCollection } from "astro:content";
import "../styles/hero.css";
import { Image } from "astro:assets";
import mobileImageSrc from "../../public/images/developer-desk-at-night-mobile.webp";
import desktopImageSrc from "../../public/images/developer-desk-at-night.webp";

const heroEntries = await getCollection("hero");
const heroEntry = heroEntries[0];

const { name, role, description, ctas, specialties } = heroEntry.data;
---

<section id="inicio" class="wp-hero" aria-label="Sección de inicio">
  <picture class="wp-hero__bg" aria-hidden="true" role="presentation">
    <source
      media="(max-width: 767px)"
      srcset={mobileImageSrc.src}
      type="image/webp"
      width="768"
      height="1024"
    />
    <Image
      src={desktopImageSrc}
      alt=""
      aria-hidden="true"
      loading="eager"
      fetchpriority="high"
      width={1920}
      height={1080}
    />
  </picture>
  <div class="wp-hero__overlay" aria-hidden="true"></div>

  <!-- Contenido principal -->
  <div
    class="wp-hero__content mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 flex flex-col items-center text-center gap-6"
  >
    <!-- Título -->
    <h1 class="wp-hero__title">
      Hola, soy {name}
    </h1>

    <!-- Rol / Badge -->
    <span class="wp-hero__role">
      {role}
    </span>

    <!-- Descripción -->
    <p class="wp-hero__description max-w-2xl">
      {description}
    </p>

    <!-- CTAs -->
    {ctas && ctas.length > 0 && (
      <div class="wp-hero__ctas flex flex-wrap justify-center gap-4 mt-2">
        {ctas.map((cta) => (
          <a
            href={cta.href}
            class:list={[
              "wp-hero__cta",
              cta.variant === "primary" ? "wp-hero__cta--primary" : "wp-hero__cta--outline"
            ]}
          >
            {cta.label}
          </a>
        ))}
      </div>
    )}

    <!-- Specialties -->
    {specialties && specialties.length > 0 && (
      <div class="wp-hero__specialties grid grid-cols-2 md:grid-cols-4 gap-4 mt-8 w-full max-w-4xl">
        {specialties.map((specialty) => (
          <div class="wp-hero__specialty flex flex-col items-center gap-3 p-4 rounded-lg bg-white/5 backdrop-blur-sm border border-white/10 hover:border-white/20 transition-colors">
            <div class="wp-hero__specialty-icon" set:html={specialty.icon} />
            <div class="text-center">
              <h2 class="wp-hero__specialty-title text-sm font-semibold">{specialty.title}</h2>
              <p class="wp-hero__specialty-desc text-xs mt-1">{specialty.description}</p>
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
