---
import { getCollection } from "astro:content";
import { Image } from "astro:assets";
import "../styles/projects.css";

const projectsEntries = await getCollection("projects");

const projects = projectsEntries
  .sort((a, b) => a.id.localeCompare(b.id))
  .map((entry) => entry.data);

// Tech icon map para los pills
const techIconMap: Record<string, string> = {
  Astro: "astro",
  "Tailwind CSS": "tailwindcss",
  TypeScript: "typescript",
  Netlify: "netlify",
  PHP: "php",
  Laravel: "laravel",
  NestJS: "nestjs",
  "Laravel 11": "laravel",
  PostgreSQL: "postgresql",
  Docker: "docker",
  Vue: "vuedotjs",
  JavaScript: "javascript",
  "Node.js": "nodedotjs",
  MySQL: "mysql",
  Git: "git",
  GitHub: "github",
  Postman: "postman",
  MariaDB: "mariadb",
};

function getTechIcon(tech: string): string | null {
  const slug = techIconMap[tech];
  if (!slug) return null;
  return `https://cdn.simpleicons.org/${slug}`;
}
---

<section id="proyectos" class="wp-projects" aria-label="Sección de proyectos">
  <div class="wp-projects__container">
    <h2 class="wp-projects__title" data-aos="fade-up" data-aos-delay="0">Proyectos destacados</h2>

    <div class="wp-projects__wrapper">
      <div class="wp-projects__grid" data-projects-container>
        {
          projects.map((project, index) => (
            <article class="wp-projects__card" data-aos="fade-up" data-aos-delay={index * 100}>
              <div class="wp-projects__card-image">
                {<Image
                  src={project.thumbnail}
                  alt={`Captura de pantalla de ${project.title}`}
                  width={400}
                  height={225}
                />}
                <div class="wp-projects__card-overlay">
                  <div class="wp-projects__card-links">
                    {project.url && (
                      <a
                        href={project.url}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="wp-projects__card-link"
                        aria-label={`Ver ${project.title} en vivo`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          width="20"
                          height="20"
                          fill="none"
                          stroke="currentColor"
                          stroke-width="2"
                          stroke-linecap="round"
                          stroke-linejoin="round"
                        >
                          <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6" />
                          <polyline points="15 3 21 3 21 9" />
                          <line x1="10" y1="14" x2="21" y2="3" />
                        </svg>
                      </a>
                    )}
                    {project.github && (
                      <a
                        href={project.github}
                        target="_blank"
                        rel="noopener noreferrer"
                        class="wp-projects__card-link"
                        aria-label={`Ver código fuente de ${project.title}`}
                      >
                        <svg
                          xmlns="http://www.w3.org/2000/svg"
                          viewBox="0 0 24 24"
                          width="20"
                          height="20"
                          fill="currentColor"
                        >
                          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z" />
                        </svg>
                      </a>
                    )}
                  </div>
                </div>
              </div>
              <div class="wp-projects__card-content">
                <h3 class="wp-projects__card-title">{project.title}</h3>

                {project.type === "institutional" && project.role && (
                  <p class="wp-projects__card-role">
                    <span class="wp-projects__card-role-label">Rol:</span>{" "}
                    {project.role}
                    {project.company && (
                      <span class="wp-projects__card-company">
                        {" "}
                        @{project.company}
                      </span>
                    )}
                  </p>
                )}

                <p class="wp-projects__card-description">{project.description}</p>

                <div class="wp-projects__card-tags">
                  {project.technologies.map((tech) => {
                    const iconUrl = getTechIcon(tech);
                    return (
                      <span class="wp-projects__tag">
                        {iconUrl && (
                          <Image
                            src={iconUrl}
                            alt=""
                            aria-hidden="true"
                            class="wp-projects__tag-icon"
                            width="14"
                            height="14"
                            loading="lazy"
                          />
                        )}
                        {tech}
                      </span>
                    );
                  })}
                </div>
              </div>
            </article>
          ))
        }
      </div>

      {
        projects.length > 3 && (
          <div class="wp-projects__pagination">
            <button
              type="button"
              class="wp-projects__btn wp-projects__btn--prev"
              data-projects-prev
              disabled
              aria-label="Proyectos anteriores"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 18 9 12 15 6" />
              </svg>
            </button>
            <span class="wp-projects__counter" data-projects-counter>
              1 - 3 de {projects.length}
            </span>
            <button
              type="button"
              class="wp-projects__btn wp-projects__btn--next"
              data-projects-next
              aria-label="Siguientes proyectos"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="9 18 15 12 9 6" />
              </svg>
            </button>
          </div>
        )
      }
    </div>
  </div>
</section>

<script src="../scripts/projects.ts"></script>
