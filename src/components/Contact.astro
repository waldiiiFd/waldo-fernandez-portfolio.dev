---
import "../styles/contact.css";
---

<section id="contacto" class="wp-contact" aria-label="Sección de contacto">
  <div class="wp-contact__container">
    <div class="wp-contact__header animate-fade-up animate-delay-0" data-animate="fade-up">
      <h2 class="wp-contact__title">Contacto</h2>
      <p class="wp-contact__subtitle">
        ¿Tiene algún proyecto en mente o quiere trabajar en conjunto conmigo? Escríbame un mensaje.
      </p>
    </div>

    <div class="wp-contact__content">
      <form 
        id="contact-form" 
        class="wp-contact__form"
        novalidate
        data-animate="fade-up"
        data-animate-delay="100"
      >
        <div class="wp-contact__grid">
          <div class="wp-contact__field">
            <label for="nombre" class="wp-contact__label">Nombre</label>
            <input
              type="text"
              id="nombre"
              name="nombre"
              class="wp-contact__input"
              placeholder="Tu nombre"
              required
            />
            <span class="wp-contact__error" data-field="nombre"></span>
          </div>

          <div class="wp-contact__field">
            <label for="correo" class="wp-contact__label">Correo electrónico</label>
            <input
              type="email"
              id="correo"
              name="correo"
              class="wp-contact__input"
              placeholder="tu@email.com"
              required
            />
            <span class="wp-contact__error" data-field="correo"></span>
          </div>
        </div>

        <div class="wp-contact__field">
          <label for="asunto" class="wp-contact__label">Asunto</label>
          <input
            type="text"
            id="asunto"
            name="asunto"
            class="wp-contact__input"
            placeholder="¿De qué se trata?"
            required
          />
          <span class="wp-contact__error" data-field="asunto"></span>
        </div>

        <div class="wp-contact__field">
          <label for="mensaje" class="wp-contact__label">Mensaje</label>
          <textarea
            id="mensaje"
            name="mensaje"
            class="wp-contact__textarea"
            placeholder="Tu mensaje..."
            rows="5"
            required
          ></textarea>
          <div class="wp-contact__counter">
            <span data-counter>0</span> / 500
          </div>
          <span class="wp-contact__error" data-field="mensaje"></span>
        </div>

        <button
          type="submit"
          class="wp-contact__submit"
          disabled
        >
          <span class="wp-contact__submit-text">Enviar Mensaje</span>
          <span class="wp-contact__submit-loading">Enviando...</span>
        </button>

        <div class="wp-contact__feedback" aria-live="polite"></div>
      </form>
    </div>
  </div>
</section>

<script src="../scripts/contact.ts"></script>
