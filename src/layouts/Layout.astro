---
import Header from '../components/Header.astro';
import Loader from '../components/Loader.astro';
import Footer from '../components/Footer.astro';
import '../styles/global.css';
import 'aos/dist/aos.css';
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta
      name="description"
      content="Portafolio de Waldo Fernández - Desarrollador Full Stack especializado en PHP, Laravel, Vue.js y tecnologías modernas web"
    />
    <link rel="icon" type="image/png" href="/letra-w.png" />
    <link rel="icon" type="image/svg+xml" href="/letra-w.png" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Canonical URL -->
    <!-- <link rel="canonical" href="https://waldofernandez.dev" /> -->
    
    <!-- Open Graph -->
    <meta property="og:title" content="Waldo Fernández | Full Stack Developer" />
    <meta property="og:description" content="Portafolio de Waldo Fernández - Desarrollador Full Stack especializado en PHP, Laravel, Vue.js y tecnologías modernas web" />
    <meta property="og:type" content="website" />
    <!-- <meta property="og:url" content="https://waldofernandez.dev" />
    <meta property="og:image" content="https://waldofernandez.dev/images/og-image.png" /> -->
    
    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="Waldo Fernández | Full Stack Developer" />
    <meta name="twitter:description" content="Portafolio de Waldo Fernández - Desarrollador Full Stack" />
    <!-- <meta name="twitter:image" content="https://waldofernandez.dev/images/og-image.png" /> -->
    
    <title>Waldo Fernández | Full Stack Developer</title>
  </head>
  <body class="antialiased">
  	<Loader />
    <Header />
    <main>
      <slot />
    </main>
    <Footer />
    <script>
      import AOS from 'aos';
      
      document.addEventListener('DOMContentLoaded', () => {
        AOS.init({
          duration: 600,
          easing: 'ease-out-cubic',
          once: true,
          offset: 100,
          startEvent: 'DOMContentLoaded',
        });
      });
    </script>
  </body>
</html>
